  "keyFeatures": [
    "Real-time class schedule with current and upcoming classes",
    "Student academic profile with GPA and enrollment details",
    "Campus building locator with distance information",
    "QR code scanner for attendance tracking",
    "Material Design 3 UI with Jetpack Compose",
    "Bottom navigation with Home, Schedule, Map, and Profile sections",
    "Fake data layer for development and testing"
  ],
  "publicApiSurface": [
    "Student(id, controlNumber, name, career, semester, average)",
    "ClassSession(id, subject, teacher, classroom, day, startHour, endHour, isCurrent)",
    "Building(id, name, description, category, distance)",
